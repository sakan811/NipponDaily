    "@upstash/vector": "^1.2.3",
    "marked": "^18.0.6",
    "nuxt": "^4.4.8",
    "ofetch": "^1.5.1",
    "tailwindcss": "^4.3.3",
    "vue": "^3.5.39",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.116",
    "@internationalized/date": "^3.12.2",
    "@nuxt/devtools": "^3.2.4",
