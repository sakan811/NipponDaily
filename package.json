    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "h3": "^1.15.11",
    "prettier": "3.9.5",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.1.5",
    "vite-tsconfig-paths": "^6.1.1",
