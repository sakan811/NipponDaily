{
  "name": "nippondaily",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "HOST=127.0.0.1 node .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "format": "pnpm exec prettier . --write",
    "type-check": "tsc --noEmit",
    "check-qa": "pnpm lint && pnpm format && pnpm type-check && pnpm build && pnpm test:run"
  },
  "dependencies": {
